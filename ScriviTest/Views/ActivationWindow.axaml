<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ScriviTest.Views.ActivationWindow"
        Title="Activate Subscription"
        Width="450" Height="280"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{DynamicResource AppBackground}">
    
    <StackPanel Margin="20" Spacing="10">
        <TextBlock Text="Step 1: Send this Request Code to the Administrator:" Foreground="{DynamicResource TextMainBrush}" FontWeight="Bold"/>
        
        <TextBox x:Name="RequestCodeBox" IsReadOnly="True" Background="{DynamicResource SurfaceVariantBrush}" 
                 Height="30" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
        
        <TextBlock Text="Step 2: Enter the Activation Key you received:" Foreground="{DynamicResource TextMainBrush}" FontWeight="Bold"/>
        
        <TextBox x:Name="InputKeyBox" Height="30" FontSize="14"/>
        
        <Button x:Name="ActivateButton" Content="Activate Now" Height="35" 
                Margin="0,15,0,0" IsDefault="True" HorizontalAlignment="Stretch" 
                HorizontalContentAlignment="Center" Background="{DynamicResource PrimaryBrush}" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold"/>
        
        <TextBlock x:Name="ErrorText" Foreground="{DynamicResource DangerBrush}" FontWeight="Bold" HorizontalAlignment="Center" IsVisible="False"/>
    </StackPanel>
</Window>