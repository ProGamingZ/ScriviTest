<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ScriviTest.ViewModels.Examiner"
             x:Class="ScriviTest.Views.Examiner.ExaminerHubView"
             x:DataType="vm:ExaminerHubViewModel"
             Background="{DynamicResource AppBackground}">

    <Grid RowDefinitions="Auto, *">
        
        <Border Grid.Row="0" Background="White" Padding="15" BoxShadow="0 2 5 0 LightGray" ZIndex="10">
            <Grid ColumnDefinitions="Auto, *">
                
                <Button Grid.Column="0" Command="{Binding GoBackCommand}" Background="Transparent" Foreground="{DynamicResource AppForeground}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{DynamicResource IconBack}"/>
                        <TextBlock Text="Back to Hub"/>
                    </StackPanel>
                </Button>
                
                <TextBlock Grid.Column="1" Text="EXAMINER WORKSPACE" FontSize="28" FontWeight="Bold" 
                           HorizontalAlignment="Center" Foreground="{DynamicResource PrimaryActionBrush}"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <Border Padding="40" MinHeight="450">
                
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20">
                    <Button Content="Create New Examination" Command="{Binding NavigateToCreationCommand}"
                            Width="300" Height="60" FontSize="18" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                            Background="{DynamicResource PrimaryActionBrush}" 
                            Foreground="{DynamicResource ActionTextBrush}"/>
                    
                    <Button Content="Exam History" Command="{Binding NavigateToHistoryCommand}"
                            Width="300" Height="60" FontSize="18" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                            Background="{DynamicResource PrimaryActionBrush}" 
                            Foreground="{DynamicResource ActionTextBrush}"/>

                    <Button Content="Grade Submitted Tests (.xans)" Command="{Binding NavigateToGradingCommand}"
                            Width="300" Height="60" FontSize="18" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                            Background="{DynamicResource SecondaryActionBrush}" 
                            Foreground="{DynamicResource ActionTextBrush}"/>
                </StackPanel>
                
            </Border>
        </ScrollViewer>
        
    </Grid>
</UserControl>