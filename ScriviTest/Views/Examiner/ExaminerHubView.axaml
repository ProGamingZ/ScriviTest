<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ScriviTest.ViewModels.Examiner"
             x:Class="ScriviTest.Views.Examiner.ExaminerHubView"
             x:DataType="vm:ExaminerHubViewModel"
             Background="{DynamicResource AppBackground}">

    <Grid RowDefinitions="Auto, *">
        <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}" Padding="15" BoxShadow="0 2 5 0 LightGray" ZIndex="10">
            <Grid>
                
                <Button Grid.Column="0" Command="{Binding GoBackCommand}" Background="Transparent" Foreground="{DynamicResource TextMainBrush}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{DynamicResource IconBack}" FontSize="20.31" FontWeight="Bold"/>
                        <TextBlock Text="BACK" VerticalAlignment="Center" FontSize="16.25" FontWeight="Bold"/>
                    </StackPanel>
                </Button>
                
                <TextBlock Grid.Column="1" Text="EXAMINER WORKSPACE" FontSize="31.74" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{DynamicResource PrimaryBrush}"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <Border Padding="40" MinHeight="450">
                
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20">
                    <Button Content="Create New Examination" Command="{Binding NavigateToCreationCommand}"
                            Width="300" Height="60" FontSize="20.31" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                            Background="{DynamicResource PrimaryBrush}" 
                            Foreground="{DynamicResource PrimaryForegroundBrush}"/>
                    
                    <Button Content="Exam History" Command="{Binding NavigateToHistoryCommand}"
                            Width="300" Height="60" FontSize="20.31" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                            Background="{DynamicResource PrimaryBrush}" 
                            Foreground="{DynamicResource PrimaryForegroundBrush}"/>

                    <Button Content="Score Submitted Tests" Command="{Binding NavigateToGradingCommand}"
                            Width="300" Height="60" FontSize="20.31" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                            Background="{DynamicResource PrimaryBrush}" 
                            Foreground="{DynamicResource PrimaryForegroundBrush}"/>
                </StackPanel>
                
            </Border>
        </ScrollViewer>
        
    </Grid>
</UserControl>