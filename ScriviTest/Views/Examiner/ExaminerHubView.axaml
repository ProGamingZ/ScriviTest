<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ScriviTest.ViewModels.Examiner"
             x:Class="ScriviTest.Views.Examiner.ExaminerHubView"
             x:DataType="vm:ExaminerHubViewModel">

    <Grid RowDefinitions="Auto, *, Auto" Margin="40">
        
        <TextBlock Grid.Row="0" Text="Examiner Workspace" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,30"/>

        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20">
            <Button Content="Create New Examination" Command="{Binding NavigateToCreationCommand}"
                    Width="300" Height="60" FontSize="18" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                    Background="#1e88e5" Foreground="White"/>
            
            <Button Content="Grade Submitted Tests (.xans)" Command="{Binding NavigateToGradingCommand}"
                    Width="300" Height="60" FontSize="18" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                    Background="#43a047" Foreground="White"/>
        </StackPanel>

        <Button Grid.Row="2" Content="← Back to Home" Command="{Binding GoBackCommand}" 
                HorizontalAlignment="Left" Background="Transparent" Foreground="Gray"/>
    </Grid>
</UserControl>