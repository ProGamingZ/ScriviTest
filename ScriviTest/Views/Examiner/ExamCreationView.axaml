<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ScriviTest.ViewModels.Examiner"
             x:Class="ScriviTest.Views.Examiner.ExamCreationView"
             x:DataType="vm:ExamCreationViewModel"
             Background="{DynamicResource AppBackground}">

    <Grid RowDefinitions="Auto, *, Auto">
        
        <Border Grid.Row="0" Background="White" Padding="15" BoxShadow="0 2 5 0 LightGray">
            <Grid ColumnDefinitions="Auto, *, Auto">
                <Button Grid.Column="0" Content="← Back" Command="{Binding GoBackCommand}" Background="Transparent" Foreground="{DynamicResource AppForeground}"/>
                <TextBlock Grid.Column="1" Text="Drafting Examination" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource AppForeground}"/>
                <Button Grid.Column="2" Content="Preview &amp; Export" Background="{DynamicResource PrimaryActionBrush}" Foreground="{DynamicResource ActionTextBrush}"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" Padding="20">
            <StackPanel Spacing="20" MaxWidth="800" HorizontalAlignment="Center">
                
                <Border Background="White" CornerRadius="8" Padding="25" BoxShadow="0 4 10 0 LightGray" BorderBrush="{DynamicResource PrimaryActionBrush}" BorderThickness="0,8,0,0">
                    <StackPanel Spacing="15">
                        <TextBox FontSize="28" FontWeight="Bold" Watermark="Untitled Exam" BorderThickness="0,0,0,1" Background="Transparent" Padding="0,5" Foreground="{DynamicResource AppForeground}"/>
                        <TextBox TextWrapping="Wrap" MinHeight="60" Watermark="Exam Instructions or Description" BorderThickness="0,0,0,1" Background="Transparent" Foreground="{DynamicResource AppForeground}"/>
                        
                        <Grid ColumnDefinitions="*, *" Margin="0,15,0,0">
                            <StackPanel Grid.Column="0" Spacing="10" Margin="0,0,10,0">
                                <TextBox Watermark="Teacher Name" Foreground="{DynamicResource AppForeground}"/>
                                <TextBox Watermark="Subject" Foreground="{DynamicResource AppForeground}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="10" Margin="10,0,0,0">
                                <TextBox Watermark="Section / Target Audience" Foreground="{DynamicResource AppForeground}"/>
                                <NumericUpDown Watermark="Time Limit (Minutes)" Minimum="0" Value="60" FormatString="{}{0} Minutes" Foreground="{DynamicResource AppForeground}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="8" Padding="25" BoxShadow="0 4 10 0 LightGray">
                    <StackPanel Spacing="15">
                        <Grid ColumnDefinitions="*, Auto">
                            <TextBox Grid.Column="0" FontSize="20" FontWeight="SemiBold" Watermark="Section Title (e.g., Test A: Multiple Choice)" BorderThickness="0,0,0,1" Background="Transparent" Foreground="{DynamicResource AppForeground}"/>
                            <ToggleSwitch Grid.Column="1" OnContent="Shuffle Questions" OffContent="Do Not Shuffle" IsChecked="True"/>
                        </Grid>
                        
                        <Border Background="{DynamicResource AppBackground}" CornerRadius="4" Padding="20" BorderBrush="{DynamicResource StandardButtonBrush}" BorderThickness="1">
                            <TextBlock Text="[ Questions will populate here ]" HorizontalAlignment="Center" Foreground="{DynamicResource AppForeground}" Opacity="0.5"/>
                        </Border>

                        <Button Content="+ Add Question to Section" HorizontalAlignment="Center" Margin="0,10,0,0" Background="{DynamicResource StandardButtonBrush}" Foreground="{DynamicResource AppForeground}"/>
                    </StackPanel>
                </Border>

                <Button Content="+ Add New Section" HorizontalAlignment="Center" Margin="0,10,0,30" Padding="20,10" Background="Transparent" BorderBrush="{DynamicResource AppForeground}" BorderThickness="1" Foreground="{DynamicResource AppForeground}"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>