<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ScriviTest.ViewModels.Examiner"
             xmlns:models="using:ScriviTest.Models" 
             x:Class="ScriviTest.Views.Examiner.ExamCreationView"
             x:Name="RootView"
             x:DataType="vm:ExamCreationViewModel"
             Background="{DynamicResource AppBackground}">

    <Grid>
        <Border ZIndex="200" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,0,0,40" Background="{Binding NotificationColor}" CornerRadius="25" Padding="15,8" BoxShadow="{DynamicResource ElevationHigh}" IsVisible="{Binding IsNotificationVisible}">
            <Grid ColumnDefinitions="Auto, *, Auto">
                
                <TextBlock Grid.Column="0" Text="{Binding NotificationIcon}" FontSize="16.25" Foreground="{DynamicResource PrimaryForegroundBrush}" VerticalAlignment="Center" Margin="10,0,12,0"/>
                <TextBlock Grid.Column="1" Text="{Binding NotificationMessage}" Foreground="{DynamicResource PrimaryForegroundBrush}" FontSize="16.25" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,25,0"/>
                
                <Button Grid.Column="2" Content="{DynamicResource IconClose}" Command="{Binding CloseToastCommand}" 
                    Background="Transparent" Foreground="{DynamicResource PrimaryForegroundBrush}" BorderThickness="0" 
                    FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Padding="8,5" CornerRadius="15"/>
            </Grid>
        </Border>

        <Grid RowDefinitions="Auto, *, Auto">
            
            <Border ZIndex="100" Background="{DynamicResource OverlayBrush}" IsVisible="{Binding IsImportPopupVisible}" Grid.RowSpan="3">
                
                <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="30" HorizontalAlignment="Center" VerticalAlignment="Center" BoxShadow="{DynamicResource ElevationHigh}" MaxWidth="500">
                    
                    <StackPanel Spacing="15">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{DynamicResource IconImport}" FontSize="24"/>
                            <TextBlock Text="Import Existing Exam" FontSize="20.31" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"/>
                        </StackPanel>
                        <TextBlock Text="Select the matching .xamn and .xamk files, and provide the decryption key to unlock and edit the exam." FontSize="16.25" TextWrapping="Wrap"/>

                        <TextBlock Text="Student Exam File (.xamn)" FontSize="16.25" FontWeight="Bold" Margin="0,10,0,0"/>
                        <Grid ColumnDefinitions="*, Auto">
                            <TextBox Grid.Column="0" Text="{Binding ImportXamnPath}" FontSize="16.25" IsReadOnly="True" PlaceholderText="Browse for .xamn..."/>
                            <Button Grid.Column="1" Content="Browse" FontSize="16.25" Command="{Binding BrowseImportXamnCommand}" Margin="10,0,0,0"/>
                        </Grid>

                        <TextBlock Text="Answer Key File (.xamk)" FontSize="16.25" FontWeight="Bold" Margin="0,5,0,0"/>
                        <Grid ColumnDefinitions="*, Auto">
                            <TextBox Grid.Column="0" Text="{Binding ImportXamkPath}" FontSize="16.25" IsReadOnly="True" PlaceholderText="Browse for .xamk..."/>
                            <Button Grid.Column="1" Content="Browse" FontSize="16.25" Command="{Binding BrowseImportXamkCommand}" Margin="10,0,0,0"/>
                        </Grid>

                        <TextBlock Text="Decryption Key" FontSize="16.25" FontWeight="Bold" Margin="0,5,0,0"/>
                        <TextBox Text="{Binding ImportDecryptionKey}" FontSize="16.25" MaxLength="6" PlaceholderText="6-Character Key" FontWeight="Bold" HorizontalContentAlignment="Center"/>

                        <TextBlock Text="{Binding ImportErrorMessage}" FontSize="16.25" Foreground="{DynamicResource DangerBrush}" FontWeight="SemiBold" IsVisible="{Binding ImportErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" TextWrapping="Wrap"/>

                        <Grid ColumnDefinitions="*, *" Margin="0,20,0,0">
                            <Button Grid.Column="0" Content="Cancel" FontSize="20.31" Command="{Binding CloseImportPopupCommand}" Background="Transparent" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="0,0,10,0" Padding="10"/>
                            <Button Grid.Column="1" Content="Unlock &amp; Import" FontSize="20.31" Command="{Binding ExecuteImportCommand}" Background="{DynamicResource PrimaryBrush}" Foreground="{DynamicResource PrimaryForegroundBrush}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="10,0,0,0" Padding="10" FontWeight="Bold"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Border>

            <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}" Padding="15" BoxShadow="{DynamicResource ElevationLow}">
                <Grid ColumnDefinitions="1*, Auto, 1*">
                    <Button Grid.Column="0" Command="{Binding GoBackCommand}" Background="Transparent" Foreground="{DynamicResource TextMainBrush}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{DynamicResource IconBack}" FontSize="20.31" FontWeight="Bold"/>
                            <TextBlock Text="BACK" VerticalAlignment="Center" FontSize="16.25" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>
                    <TextBlock Grid.Column="1" Text="CREATING EXAM" FontWeight="Bold" FontSize="31.74" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryBrush}"/>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="15" HorizontalAlignment="Right" VerticalAlignment="Center"> 
                        <Button Command="{Binding OpenImportPopupCommand}" Background="Transparent" BorderBrush="{DynamicResource TextMainBrush}" Foreground="{DynamicResource TextMainBrush}" BorderThickness="2" Padding="15,5" VerticalAlignment="Center" FontWeight="Bold">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{DynamicResource IconImport}" FontSize="16.25"/>
                                <TextBlock Text="Import" FontSize="16.25"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding OverwriteExamCommand}" Background="Transparent" BorderBrush="{DynamicResource TextMainBrush}" Foreground="{DynamicResource TextMainBrush}" BorderThickness="2" Padding="15,5" VerticalAlignment="Center" FontWeight="Bold">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{DynamicResource IconSave}" FontSize="16.25"/>
                                <TextBlock Text="Overwrite" FontSize="16.25"/>
                            </StackPanel>
                        </Button>
                        <Button Content="Export" FontWeight="Bold" FontSize="16.25" Command="{Binding ExportExamCommand}" Background="Transparent" BorderBrush="{DynamicResource TextMainBrush}" Foreground="{DynamicResource TextMainBrush}" BorderThickness="2" Padding="15,5"/>
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" Padding="20">
                <StackPanel Spacing="20" MaxWidth="800" HorizontalAlignment="Center" >  
                    
                    <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="25" BoxShadow="{DynamicResource ElevationMid}" BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="1,8,1,3">
                        <StackPanel Spacing="15">
                            <Grid ColumnDefinitions="*, Auto">
                                <TextBox Grid.Column="0" FontSize="16.25" FontWeight="Bold" Text="{Binding ExamTitle}" PlaceholderText="Untitled Exam" BorderThickness="0,0,0,1" Background="Transparent" Padding="0,5" Foreground="{DynamicResource TextMainBrush}" />
                                <TextBlock Grid.Column="1" Text="{Binding TotalExamPoints, StringFormat='Total Points: {0}'}" Padding="5,0,0,5" FontSize="16.25" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBox Text="{Binding ExamDescription}" TextWrapping="Wrap" MinHeight="60" PlaceholderText="Exam Instructions or Description" BorderThickness="0,0,0,1" Background="Transparent" Foreground="{DynamicResource TextMainBrush}" FontSize="13"/>

                            <WrapPanel Margin="0,20,0,0" Orientation="Horizontal">
                                <StackPanel Width="230" Margin="0,0,15,15">
                                    <TextBlock Text="Teacher Name" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextMainBrush}" Margin="0,0,0,5"/>
                                    <TextBox Text="{Binding TeacherName}" FontSize="13" Foreground="{DynamicResource TextMainBrush}"/>
                                </StackPanel>

                                <StackPanel Width="230" Margin="0,0,15,15">
                                    <TextBlock Text="Subject" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextMainBrush}" Margin="0,0,0,5"/>
                                    <TextBox Text="{Binding Subject}" FontSize="13" Foreground="{DynamicResource TextMainBrush}"/>
                                </StackPanel>

                                <StackPanel Width="230" Margin="0,0,15,15">
                                    <TextBlock Text="Section / Audience" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextMainBrush}" Margin="0,0,0,5"/>
                                    <TextBox Text="{Binding TargetSection}" FontSize="13" Foreground="{DynamicResource TextMainBrush}"/>
                                </StackPanel>

                                <StackPanel Width="230" Margin="0,0,15,15">
                                    <TextBlock Text="Time Limit (Minutes)" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextMainBrush}" Margin="0,0,0,5"/>
                                    <NumericUpDown Value="{Binding TimeLimitMinutes}" FontSize="13" Minimum="1" Maximum="1440" FormatString="0" ParsingNumberStyle="Integer" Foreground="{DynamicResource TextMainBrush}" HorizontalAlignment="Stretch"/>
                                </StackPanel>

                                <StackPanel Width="230" Margin="0,0,15,15">
                                    <TextBlock Text="Anti-Cheat Strictness" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextMainBrush}" Margin="0,0,0,5"/>
                                    <ComboBox SelectedItem="{Binding AntiCheatStrictness}" HorizontalAlignment="Stretch">
                                        <x:String>Strict</x:String>
                                        <x:String>Lenient</x:String>
                                        <x:String>Log Only</x:String>
                                    </ComboBox>
                                </StackPanel>
                            </WrapPanel>

                        </StackPanel>
                    </Border>

                    <ItemsRepeater ItemsSource="{Binding Sections}">
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="models:TestSection">
                                
                                <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="25" BoxShadow="{DynamicResource ElevationMid}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,8,1,3" Margin="0,0,0,80">
                                    <StackPanel Spacing="15">
                                        
                                        <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            
                                            <TextBox Text="{Binding Title}" FontSize="16.25" FontWeight="SemiBold" PlaceholderText="Section Title" BorderThickness="0,0,0,1" Background="Transparent" Foreground="{DynamicResource TextMainBrush}" MinWidth="250" Margin="0,0,20,10"/>
                                            
                                            <TextBlock Text="{Binding SectionTotalPoints, StringFormat='Section Points: {0}'}" FontSize="16.25"
                                                    VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{DynamicResource TextMainBrush}" Margin="0,0,20,10"/>

                                            <ToggleSwitch IsChecked="{Binding ShuffleQuestions}" FontSize="16.25" OnContent="Shuffle Questions" OffContent="Do Not Shuffle" Margin="0,0,20,10"/>
                                            
                                            <Button Content="{DynamicResource IconDelete}" 
                                                    Command="{Binding #RootView.DataContext.RemoveSectionCommand}" 
                                                    CommandParameter="{Binding}"
                                                    Background="Transparent" Foreground="{DynamicResource DangerBrush}" FontSize="16.25" ToolTip.Tip="Delete Entire Section" Margin="0,0,0,10"/>
                                        </WrapPanel>
                                        
                                        <ItemsRepeater ItemsSource="{Binding Questions}">
                                            <ItemsRepeater.ItemTemplate>
                                                <DataTemplate x:DataType="models:Question">
                                                    <Border Background="{DynamicResource SurfaceVariantBrush}" CornerRadius="6" Padding="15" BorderThickness="1" Margin="0,0,0,15">
                                                        <Grid RowDefinitions="Auto, Auto">
                                                            
                                                            <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto, Auto">
                                                                <TextBlock Grid.Column="0" Text="{Binding Type}" FontSize="16.25" FontWeight="Bold" Margin="0,0,10,0" VerticalAlignment="Center" Foreground="{DynamicResource TextMainBrush}" />
                                                                <TextBox Grid.Column="1" Text="{Binding Prompt}" FontSize="16.25" PlaceholderText="Type your question here..." Background="Transparent" BorderThickness="0,0,0,1" Foreground="{DynamicResource TextMainBrush}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="40"/>
                                                                <Button Grid.Column="2" Content="{Binding ExpandCollapseIcon}" FontSize="16.25" Command="{Binding ToggleExpandCommand}" Width="30" Height="30" CornerRadius="15" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Background="Transparent" BorderBrush="{DynamicResource TextMainBrush}" BorderThickness="1" Margin="10,0,0,0" Foreground="{DynamicResource TextMainBrush}" FontWeight="Bold"/>
                                                                <Button Grid.Column="3" Content="{DynamicResource IconDelete}" FontSize="16.25" Command="{Binding #RootView.DataContext.RemoveQuestionCommand}" CommandParameter="{Binding}" Background="Transparent" Foreground="{DynamicResource DangerBrush}" Margin="10,0,0,0" ToolTip.Tip="Delete Question"/>
                                                            </Grid>

                                                            <StackPanel Grid.Row="1" IsVisible="{Binding IsExpanded}" Margin="0,15,0,0" Spacing="10">
                                                                
                                                                <StackPanel IsVisible="{Binding IsMultipleChoice}" Spacing="10">
                                                                    <ItemsRepeater ItemsSource="{Binding Choices}">
                                                                        <ItemsRepeater.ItemTemplate>
                                                                            <DataTemplate x:DataType="models:Choice">
                                                                                <Grid ColumnDefinitions="Auto, *, Auto, Auto" Margin="0,0,0,10">
                                                                                    <RadioButton Grid.Column="0" IsChecked="{Binding IsCorrect}" GroupName="{Binding $parent[ItemsRepeater].DataContext.GroupId}" Margin="0,0,10,0"/>
                                                                                    
                                                                                    <StackPanel Grid.Column="1" Spacing="5">
                                                                                        <TextBox Text="{Binding Text}" FontSize="13" PlaceholderText="Option text..." Foreground="{DynamicResource TextMainBrush}" AcceptsReturn="True" TextWrapping="Wrap"/>
                                                                                        
                                                                                        <Border IsVisible="{Binding HasImage}" CornerRadius="4" Padding="5" HorizontalAlignment="Left">
                                                                                            <StackPanel Orientation="Horizontal" Spacing="5">
                                                                                                <TextBlock Text="{DynamicResource IconImage}" FontSize="13" VerticalAlignment="Center"/>
                                                                                                <TextBlock Text="{Binding AttachedImageFileName}" FontSize="13" VerticalAlignment="Center" MaxWidth="120" TextTrimming="CharacterEllipsis"/>
                                                                                                <Button Content="{DynamicResource IconClose}" FontSize="13" Command="{Binding #RootView.DataContext.RemoveChoiceImageCommand}" CommandParameter="{Binding}" Background="Transparent" Foreground="{DynamicResource DangerBrush}" Padding="5,0"/>
                                                                                            </StackPanel>
                                                                                        </Border>
                                                                                    </StackPanel>
                                                                                    
                                                                                    <Button Grid.Column="2" Content="{DynamicResource IconImage}" FontSize="16.25" Command="{Binding #RootView.DataContext.AttachChoiceImageCommand}" CommandParameter="{Binding}" Background="Transparent" ToolTip.Tip="Attach image to choice" Margin="5,0"/>
                                                                                    
                                                                                    <Button Grid.Column="3" Content="{DynamicResource IconClose}" FontSize="16.25" Command="{Binding $parent[ItemsRepeater].DataContext.RemoveChoiceCommand}" CommandParameter="{Binding}" Background="Transparent" Foreground="{DynamicResource DangerBrush}" Margin="5,0,0,0"/>
                                                                                </Grid>
                                                                            </DataTemplate>
                                                                        </ItemsRepeater.ItemTemplate>
                                                                    </ItemsRepeater>
                                                                    <Button Content="+ Add Option" FontSize="16.25" Command="{Binding AddChoiceCommand}" Background="Transparent" Foreground="{DynamicResource PrimaryBrush}" BorderBrush="{DynamicResource BorderBrush}" HorizontalAlignment="Left"/>
                                                                </StackPanel>

                                                                <StackPanel IsVisible="{Binding IsTrueFalse}" Spacing="10">
                                                                    <RadioButton Content="True" GroupName="{Binding GroupId}" IsChecked="{Binding IsTrueFalseAnswerTrue}" Foreground="{DynamicResource TextMainBrush}"/>
                                                                    <RadioButton Content="False" GroupName="{Binding GroupId}" IsChecked="{Binding IsTrueFalseAnswerFalse}" Foreground="{DynamicResource TextMainBrush}"/>
                                                                </StackPanel>

                                                                <StackPanel IsVisible="{Binding IsMultipleAnswer}" Spacing="10">
                                                                    <ItemsRepeater ItemsSource="{Binding Choices}">
                                                                        <ItemsRepeater.ItemTemplate>
                                                                            <DataTemplate x:DataType="models:Choice">
                                                                                <Grid ColumnDefinitions="Auto, *, Auto, Auto" Margin="0,0,0,10">
                                                                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsCorrect}"  Margin="0,0,10,0"/>
                                                                                    
                                                                                    <StackPanel Grid.Column="1" Spacing="5">
                                                                                        <TextBox Text="{Binding Text}" FontSize="13" PlaceholderText="Option text..." Foreground="{DynamicResource TextMainBrush}" AcceptsReturn="True" TextWrapping="Wrap"/>
                                                                                        
                                                                                        <Border IsVisible="{Binding HasImage}" Background="{DynamicResource InfoBrush}" CornerRadius="4" Padding="5" HorizontalAlignment="Left">
                                                                                            <StackPanel Orientation="Horizontal" Spacing="5">
                                                                                                <TextBlock Text="{DynamicResource IconImage}" FontSize="13" VerticalAlignment="Center"/>
                                                                                                <TextBlock Text="{Binding AttachedImageFileName}" FontSize="13" VerticalAlignment="Center" MaxWidth="120" TextTrimming="CharacterEllipsis"/>
                                                                                                <Button Content="{DynamicResource IconClose}" FontSize="13" Command="{Binding #RootView.DataContext.RemoveChoiceImageCommand}" CommandParameter="{Binding}" Background="Transparent" Foreground="{DynamicResource DangerBrush}" Padding="5,0"/>
                                                                                            </StackPanel>
                                                                                        </Border>
                                                                                    </StackPanel>
                                                                                    
                                                                                    <Button Grid.Column="2" Content="{DynamicResource IconImage}" FontSize="16.25" Command="{Binding #RootView.DataContext.AttachChoiceImageCommand}" CommandParameter="{Binding}"  Background="Transparent" ToolTip.Tip="Attach image to choice" Margin="5,0"/>
                                                                                    
                                                                                    <Button Grid.Column="3" Content="{DynamicResource IconClose}" FontSize="16.25" Command="{Binding $parent[ItemsRepeater].DataContext.RemoveChoiceCommand}" CommandParameter="{Binding}" Background="Transparent" Foreground="{DynamicResource DangerBrush}" Margin="5,0,0,0"/>
                                                                                </Grid>
                                                                            </DataTemplate>
                                                                        </ItemsRepeater.ItemTemplate>
                                                                    </ItemsRepeater>
                                                                    <Grid ColumnDefinitions="Auto, *, Auto, Auto" Margin="0,10,0,0">
                                                                        <Button Grid.Column="0" Content="+ Add Checkbox" FontSize="16.25" Command="{Binding AddChoiceCommand}" Background="Transparent" Foreground="{DynamicResource PrimaryBrush}"/>
                                                                        <TextBlock Grid.Column="2" Text="Scoring Rubric:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{DynamicResource TextMainBrush}"/>
                                                                        <ComboBox Grid.Column="3" SelectedIndex="{Binding MultipleAnswerRubric}" Width="200">
                                                                            <ComboBoxItem>All-or-Nothing</ComboBoxItem>
                                                                            <ComboBoxItem>Partial Credit (-1 penalty)</ComboBoxItem>
                                                                        </ComboBox>
                                                                    </Grid>
                                                                </StackPanel>

                                                                <StackPanel IsVisible="{Binding IsEssay}" Spacing="10">
                                                                    <TextBox MinHeight="100" PlaceholderText="The examinee will type their essay response here..." IsEnabled="False" TextWrapping="Wrap" Background="{DynamicResource SurfaceVariantBrush}"/>
                                                                    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                                                                        <TextBlock Text="Max Word Count:" VerticalAlignment="Center" Foreground="{DynamicResource TextMainBrush}"/>
                                                                        <NumericUpDown Value="{Binding MaxWordCount}" Minimum="50" Maximum="2000" Width="120" FormatString="0" ParsingNumberStyle="Integer" Foreground="{DynamicResource TextMainBrush}"/>
                                                                    </StackPanel>
                                                                </StackPanel>   
                                                                
                                                                <Grid ColumnDefinitions="*, Auto" Margin="0,15,0,0">
                                                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                                                                        <Button Content="Attach Image" FontSize="16.25" Command="{Binding #RootView.DataContext.AttachImageCommand}" CommandParameter="{Binding}" Background="Transparent" Foreground="{DynamicResource PrimaryBrush}" BorderThickness="1" BorderBrush="{DynamicResource PrimaryBrush}"/>
                                                                        <Border IsVisible="{Binding HasImage}" CornerRadius="4" Padding="10,5">
                                                                            <StackPanel Orientation="Horizontal" Spacing="5">
                                                                                <TextBlock Text="{DynamicResource IconImage}" VerticalAlignment="Center"/>
                                                                                <TextBlock Text="{Binding AttachedImageFileName}" VerticalAlignment="Center" MaxWidth="150" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextMainBrush}"/>
                                                                                <Button Content="{DynamicResource IconClose}" Command="{Binding #RootView.DataContext.RemoveImageCommand}" CommandParameter="{Binding}" Background="Transparent" Foreground="{DynamicResource DangerBrush}" Padding="5,0"/>
                                                                            </StackPanel>
                                                                        </Border>
                                                                    </StackPanel>
                                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                                                                        <TextBlock Text="Points:" VerticalAlignment="Center" Foreground="{DynamicResource TextMainBrush}"/>
                                                                        <NumericUpDown Value="{Binding Points}" Minimum="1" Maximum="100" Width="120" FormatString="0" ParsingNumberStyle="Integer" Foreground="{DynamicResource TextMainBrush}"/>
                                                                    </StackPanel>
                                                                </Grid>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsRepeater.ItemTemplate>
                                        </ItemsRepeater>

                                        <Button Content="+ Add Question to Section" FontSize="16.25" HorizontalAlignment="Center" Margin="0,10,0,0" Background="Transparent" BorderBrush="{DynamicResource BorderBrush}" Foreground="{DynamicResource PrimaryBrush}" BorderThickness="2" Padding="30,10" FontWeight="Bold">
                                            <Button.Flyout>
                                                <MenuFlyout Placement="BottomEdgeAlignedLeft">
                                                    <MenuItem Header="Multiple Choice" Command="{Binding #RootView.DataContext.AddMultipleChoiceCommand}" CommandParameter="{Binding}" />
                                                    <MenuItem Header="True/False" Command="{Binding #RootView.DataContext.AddTrueFalseCommand}" CommandParameter="{Binding}" />
                                                    <MenuItem Header="Multiple Answer" Command="{Binding #RootView.DataContext.AddMultipleAnswerCommand}" CommandParameter="{Binding}" />
                                                    <MenuItem Header="Essay" Command="{Binding #RootView.DataContext.AddEssayCommand}" CommandParameter="{Binding}" />
                                                </MenuFlyout>
                                            </Button.Flyout>
                                        </Button>
                                        
                                    </StackPanel>
                                </Border>

                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>

                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" Padding="15" BoxShadow="{DynamicResource ElevationLow}" ZIndex="10">
                <Button Content="+ Add New Section"  Command="{Binding AddSectionCommand}" HorizontalAlignment="Center" 
                        Background="Transparent" Foreground="{DynamicResource PrimaryBrush}" BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="2" 
                        Padding="30,10" FontSize="16.25" FontWeight="Bold"/>
            </Border>
        </Grid>

    </Grid>
</UserControl>