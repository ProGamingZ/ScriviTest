<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:components="using:ScriviTest.Views.Components"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ScriviTest.ViewModels.Examiner"
             xmlns:models="using:ScriviTest.Models"
             x:Class="ScriviTest.Views.Examiner.ExamHistoryView"
             x:DataType="vm:ExamHistoryViewModel"
             Background="{DynamicResource AppBackground}">

    <Grid>
        <!-- MASTER LAYOUT GRID -->
        <components:HelpTourOverlay  ZIndex="201" DataContext="{Binding HelpTour}" />
        <Grid RowDefinitions="Auto, *">
            
            <!-- HEADER -->
            <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}" Padding="15" BoxShadow="{DynamicResource ElevationLow}" ZIndex="10">
                <Grid>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="15" VerticalAlignment="Center">
                        <Button Command="{Binding GoBackCommand}" Background="Transparent" Foreground="{DynamicResource TextMainBrush}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Classes="icon" Text="{DynamicResource IconBack}" FontSize="20.31" FontWeight="Bold"/>
                                <TextBlock Text="BACK" VerticalAlignment="Center" FontSize="16.25" FontWeight="Bold"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding OpenHelpTourCommand}" Background="Transparent" BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="1" Foreground="{DynamicResource PrimaryBrush}" Padding="10,5" CornerRadius="4">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Help &amp; Tips" VerticalAlignment="Center" FontSize="16.25" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="EXAM HISTORY" FontSize="31.74" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{DynamicResource PrimaryBrush}"/>
                </Grid>
            </Border>
            
            <!-- MAIN CONTENT -->
            <Grid Grid.Row="1" ColumnDefinitions="Auto, *">
                
                <!-- LEFT PANEL: ACTION BUTTONS -->
                <Border Grid.Column="0" Width="250" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,4,0" Padding="15" Background="{DynamicResource SurfaceBrush}">
                    <Grid RowDefinitions="Auto, Auto, Auto, *, Auto">
                        
                        <Button Grid.Row="0" Content="Check Locations" FontSize="16.25" Command="{Binding CheckLocationsCommand}" 
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="Transparent"
                                Foreground="{DynamicResource TextMainBrush}" BorderBrush="{DynamicResource TextMainBrush}" BorderThickness="2" Margin="0,0,0,15" Padding="10"/>

                        <Button Grid.Row="1" Content="Relink Missing File" FontSize="16.25" Command="{Binding PromptRelinkCommand}" 
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="Transparent"
                                Foreground="{DynamicResource TextMainBrush}" BorderBrush="{DynamicResource TextMainBrush}" BorderThickness="2" Margin="0,0,0,15" Padding="10"/>

                        <Button Grid.Row="2" Content="Delete Selected File" FontSize="16.25" Command="{Binding AttemptDeleteCommand}" 
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="Transparent"
                                Foreground="{DynamicResource DangerBrush}" BorderBrush="{DynamicResource DangerBrush}" BorderThickness="2" FontWeight="Bold" Margin="0,0,0,15" Padding="10"/>

                        <!-- COLUMN TOGGLES -->
                        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                            <Button FontSize="20.31" Background="Transparent" BorderBrush="{DynamicResource TableBorderBrush}" Padding="10,5">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Classes="icon" Text="{DynamicResource IconSettings}"/>
                                    <TextBlock Text="Toggle Columns" Foreground="{DynamicResource TextMainBrush}"/>
                                </StackPanel>
                                
                                <Button.Flyout>
                                    <Flyout>
                                        <StackPanel Spacing="10" MinWidth="150">
                                            <TextBlock Text="Show/Hide Columns" FontSize="16.25" FontWeight="Bold" Margin="0,0,0,5"/>
                                            <CheckBox Content="Date Created" FontSize="16.25" IsChecked="{Binding ShowDate}"/>
                                            <CheckBox Content="Exam Title" FontSize="16.25" IsChecked="{Binding ShowTitle}"/>
                                            <CheckBox Content="Decryption Key" FontSize="16.25" IsChecked="{Binding ShowKey}"/>
                                            <CheckBox Content="File Status" FontSize="16.25" IsChecked="{Binding ShowStatus}"/>
                                            <CheckBox Content="File Path" FontSize="16.25" IsChecked="{Binding ShowLocation}"/>
                                        </StackPanel>
                                    </Flyout>
                                </Button.Flyout>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Column="1" RowDefinitions="*, 4, *" Background="{DynamicResource SurfaceVariantBrush}">
                    <Border Grid.Row="0" Padding="20">
                        <Grid RowDefinitions="Auto, *">
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,10">
                                <TextBlock Classes="icon" Text="{DynamicResource IconDoc}" FontWeight="Bold" FontSize="20.31"/>
                                <TextBlock Text="Exported Questionnaires (.xamn)" FontSize="20.31" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}"/>
                            </StackPanel>
                            
                            <DataGrid x:Name="QuestionnaireGrid" Grid.Row="1" ItemsSource="{Binding QuestionnaireList}" SelectedItem="{Binding SelectedQuestionnaire}" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="All" BorderBrush="{DynamicResource TableBorderBrush}" BorderThickness="1" RowBackground="{DynamicResource SurfaceBrush}" CanUserSortColumns="True" CanUserReorderColumns="True" CanUserResizeColumns="True" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Date" SortMemberPath="Record.ExportDate" FontSize="16.25" Binding="{Binding Record.ExportDate}" IsVisible="{Binding ShowDate}" MinWidth="200" MaxWidth="200"/>
                                    <DataGridTextColumn Header="Exam Title" SortMemberPath="Record.ExamTitle" FontSize="16.25" Binding="{Binding Record.ExamTitle}" IsVisible="{Binding ShowTitle}" MinWidth="150" MaxWidth="1500"  Width="Auto"/>
                                    <DataGridTextColumn Header="Key" SortMemberPath="DisplayKey" FontSize="16.25" Binding="{Binding DisplayKey}" IsVisible="{Binding ShowKey}" MinWidth="110"  MaxWidth="110"/>
                                    <DataGridTemplateColumn Header="Status" SortMemberPath="FileStatus" IsVisible="{Binding ShowStatus}" MinWidth="110" MaxWidth="110">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate x:DataType="vm:HistoryRecordWrapper">
                                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="10,0">
                                                    <Ellipse Width="10" Height="10" Fill="{Binding StatusHexColor}"/>
                                                    <TextBlock Text="{Binding FileStatus}" FontSize="16.25" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Location" SortMemberPath="Record.FilePath" FontSize="16.25" Binding="{Binding Record.FilePath}" IsVisible="{Binding ShowLocation}" MinWidth="200" MaxWidth="2000" Width="Auto"/>
                                </DataGrid.Columns>
                            </DataGrid>

                        </Grid>
                    </Border>

                    <!-- DIVIDER -->
                    <GridSplitter Grid.Row="1" Background="{DynamicResource BorderBrush}" ResizeDirection="Rows" HorizontalAlignment="Stretch" Height="4"/>

                    <Border Grid.Row="2" Padding="20">
                        <Grid RowDefinitions="Auto, *">
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,10">
                                <TextBlock Classes="icon" Text="{DynamicResource IconKey}" FontWeight="Bold" FontSize="20.31"/>
                                <TextBlock Text="Exported Answer Keys (.xamk)" FontSize="20.31" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}"/>
                            </StackPanel>
                            
                            <DataGrid x:Name="AnswerKeyGrid" Grid.Row="1" ItemsSource="{Binding AnswerKeyList}" SelectedItem="{Binding SelectedAnswerKey}"
                                      AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="All" BorderBrush="{DynamicResource TableBorderBrush}" BorderThickness="1"
                                      RowBackground="{DynamicResource SurfaceBrush}" 
                                      CanUserSortColumns="True" CanUserReorderColumns="True" CanUserResizeColumns="True" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto" >
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Date" SortMemberPath="Record.ExportDate" FontSize="16.25" Binding="{Binding Record.ExportDate}" IsVisible="{Binding ShowDate}" MinWidth="120"  MaxWidth="120"/>
                                    <DataGridTextColumn Header="Exam Title" SortMemberPath="Record.ExamTitle" FontSize="16.25" Binding="{Binding Record.ExamTitle}" IsVisible="{Binding ShowTitle}" MinWidth="150" MaxWidth="1500"  Width="Auto"/>
                                    <DataGridTextColumn Header="Key" SortMemberPath="DisplayKey" FontSize="16.25" Binding="{Binding DisplayKey}" IsVisible="{Binding ShowKey}" MinWidth="85"  MaxWidth="85"/>
                                    <DataGridTemplateColumn Header="Status" SortMemberPath="FileStatus" IsVisible="{Binding ShowStatus}" MinWidth="110"  MaxWidth="110">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate x:DataType="vm:HistoryRecordWrapper">
                                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="10,0">
                                                    <Ellipse Width="10" Height="10" Fill="{Binding StatusHexColor}"/>
                                                    <TextBlock Text="{Binding FileStatus}" FontSize="16.25" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Location" SortMemberPath="Record.FilePath" FontSize="16.25" Binding="{Binding Record.FilePath}" IsVisible="{Binding ShowLocation}" MinWidth="200" MaxWidth="2000" Width="Auto"/>
                                </DataGrid.Columns>
                            </DataGrid>

                        </Grid>
                    </Border>
                    
                </Grid>
            </Grid>
        </Grid>

        <!-- DELETE WARNING MODAL -->
        <Border Background="{DynamicResource OverlayBrush}" IsVisible="{Binding IsDeleteWarningVisible}" ZIndex="50">
            <Border Background="{DynamicResource SurfaceBrush}" Width="400" Padding="30" CornerRadius="8" HorizontalAlignment="Center" VerticalAlignment="Center" BoxShadow="{DynamicResource ElevationHigh}">
                <StackPanel Spacing="15">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                        <TextBlock Classes="icon" Text="{DynamicResource IconWarning}" FontSize="20.31" Foreground="{DynamicResource DangerBrush}"/>
                        <TextBlock Text="Permanent Delete Warning" FontSize="20.31" FontWeight="Bold" Foreground="{DynamicResource DangerBrush}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding DeleteWarningMessage}" TextWrapping="Wrap" FontSize="16" TextAlignment="Center" Margin="0,10"/>
                    <Grid ColumnDefinitions="*, *">
                        <Button Grid.Column="0" Content="Cancel" FontSize="20.31" Command="{Binding CancelDeleteCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="0,0,5,0" Padding="10"/>

                        <Button Grid.Column="1" Content="DELETE" FontSize="20.31" Command="{Binding ConfirmDeleteCommand}" Background="{DynamicResource DangerBrush}" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="5,0,0,0" Padding="10"/>

                    </Grid>
                </StackPanel>
            </Border>
        </Border>

        <!-- TOAST NOTIFICATION -->
        <Border VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,0,0,40" Padding="20,12" 
                Background="{Binding NotificationColor}" CornerRadius="8" IsVisible="{Binding IsNotificationVisible}" 
                BoxShadow="{DynamicResource ElevationHigh}" ZIndex="100">
            <Grid ColumnDefinitions="Auto, *, Auto">
                <TextBlock Classes="icon" Grid.Column="0" Text="{Binding NotificationIcon}" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="Bold" FontSize="20.31" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock Grid.Column="1" Text="{Binding NotificationMessage}" FontSize="20.31" Foreground="{DynamicResource PrimaryForegroundBrush}" FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="500"/>
                <Button Classes="icon" Grid.Column="2" Content="{DynamicResource IconClose}" FontSize="20.31" Command="{Binding CloseToastCommand}" Background="Transparent" Foreground="{DynamicResource TextMainBrush}"  FontWeight="Bold" Margin="15,0,0,0" Padding="8,4" Cursor="Hand"/>
            </Grid>
        </Border>

    </Grid>
</UserControl>