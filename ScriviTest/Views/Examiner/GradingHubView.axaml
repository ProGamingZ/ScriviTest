<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ScriviTest.ViewModels.Examiner"
             xmlns:models="using:ScriviTest.Models"
             x:Name="RootView"
             x:Class="ScriviTest.Views.Examiner.GradingHubView"
             x:DataType="vm:GradingHubViewModel"
             Background="{DynamicResource AppBackground}">

    <Grid RowDefinitions="Auto, *">
        
        <Border Grid.Row="0" Background="White" Padding="15" BoxShadow="0 2 5 0 LightGray" ZIndex="10">
            <Grid ColumnDefinitions="Auto, *">
                <Button Grid.Column="0" Content="← back to hub" Command="{Binding GoBackCommand}" Background="Transparent" Foreground="{DynamicResource AppForeground}"/>
                <TextBlock Grid.Column="1" Text="GRADING DASHBOARD" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{DynamicResource PrimaryActionBrush}"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="2.5*, 5*, 2.5*">
            
            <Border Grid.Column="0" BorderBrush="Black" BorderThickness="0,0,4,0" Padding="15" Background="White">
                <Grid RowDefinitions="Auto, Auto, Auto, Auto, *, Auto">
                    
                    <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,10">
                        <TextBox Grid.Column="0" Text="{Binding AnswerKeyFileName}" Watermark="Load Answer Key (.xamk)" IsReadOnly="True" BorderBrush="Black" BorderThickness="1" CornerRadius="0"/>
                        <Button Grid.Column="1" Content="Browse" Command="{Binding BrowseForAnswerKeyCommand}" BorderBrush="Black" BorderThickness="1,1,1,1" CornerRadius="0" Margin="5,0,0,0" Background="White"/>
                    </Grid>

                    <Grid Grid.Row="1" ColumnDefinitions="*, Auto" Margin="0,0,0,10">
                        <TextBox Grid.Column="0" Text="{Binding WhiteboardKey}" Watermark="Decryption Key" BorderBrush="Black" BorderThickness="1" CornerRadius="0"/>
                        <Button Grid.Column="1" Content="Check" Command="{Binding CheckAndUnlockCommand}" BorderBrush="Black" BorderThickness="1,1,1,1" CornerRadius="0" Margin="5,0,0,0" Background="White"/>
                    </Grid>

                    <Grid Grid.Row="2" ColumnDefinitions="*, Auto" Margin="0,0,0,15">
                        <TextBox Grid.Column="0" Text="{Binding StudentFilesSummary}" Watermark="Load Student Submissions (.xans)" IsReadOnly="True" BorderBrush="Black" BorderThickness="1" CornerRadius="0"/>
                        <Button Grid.Column="1" Content="Browse" Command="{Binding BrowseForStudentFilesCommand}" BorderBrush="Black" BorderThickness="1,1,1,1" CornerRadius="0" Margin="5,0,0,0" Background="White"/>
                    </Grid>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,5">
                        <Button Content="⚙️ Columns" Background="Transparent" BorderBrush="Gray" BorderThickness="1" Padding="10,5">
                            <Button.Flyout>
                                <Flyout>
                                    <StackPanel Spacing="10" MinWidth="150">
                                        <TextBlock Text="Show/Hide Columns" FontWeight="Bold" Margin="0,0,0,5"/>
                                        <CheckBox Content="First Name" IsChecked="{Binding ShowFirstName}"/>
                                        <CheckBox Content="Middle Name" IsChecked="{Binding ShowMiddleName}"/>
                                        <CheckBox Content="Last Name" IsChecked="{Binding ShowLastName}"/>
                                        <CheckBox Content="Student ID" IsChecked="{Binding ShowID}"/>
                                        <CheckBox Content="Scores" IsChecked="{Binding ShowScores}"/>
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                    </StackPanel>

                    <DataGrid Grid.Row="4" ItemsSource="{Binding StudentList}" SelectedItem="{Binding SelectedStudent}"
                              AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="All" BorderBrush="Black" BorderThickness="1"
                              CanUserReorderColumns="True" CanUserSortColumns="True"
                              CanUserResizeColumns="True"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto" 
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              RowBackground="White">
                                <DataGrid.Styles>
                                    <Style Selector="DataGridRow:nth-child(odd)">
                                        <Setter Property="Background" Value="#ddddddf5"/>
                                    </Style>
                                    <Style Selector="DataGridRow:selected /template/ Rectangle#BackgroundRectangle">
                                        <Setter Property="Fill" Value="#D0E8FF"/> 
                                    </Style>
                                    <Style Selector="DataGridRow:selected:pointerover /template/ Rectangle#BackgroundRectangle">
                                        <Setter Property="Fill" Value="#BBE0FF"/>
                                    </Style>
                                    
                                </DataGrid.Styles>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="First" Binding="{Binding FirstName}" Width="Auto" MinWidth="100" MaxWidth="300" IsVisible="{Binding ShowFirstName}"/>
                            <DataGridTextColumn Header="Middle" Binding="{Binding MiddleName}" Width="Auto" MinWidth="100" MaxWidth="300" IsVisible="{Binding ShowMiddleName}"/>
                            <DataGridTextColumn Header="Last" Binding="{Binding LastName}" Width="Auto" MinWidth="100" MaxWidth="300" IsVisible="{Binding ShowLastName}"/>
                            <DataGridTextColumn Header="ID" Binding="{Binding StudentID}" Width="Auto" MinWidth="100" MaxWidth="250" IsVisible="{Binding ShowID}"/>
                            
                            <DataGridTemplateColumn Header="Score Status" Width="Auto" MinWidth="140" MaxWidth="250" IsVisible="{Binding ShowScores}" SortMemberPath="TotalPointsEarned">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate x:DataType="models:GradeReport">
                                        <StackPanel Orientation="Horizontal" Spacing="10" Margin="10,0,0,0" VerticalAlignment="Center">
                                            
                                            <Ellipse Width="14" Height="14" Fill="{Binding StatusHexColor}" ToolTip.Tip="{Binding StatusTooltip}"/>
                                            
                                            <TextBlock Text="{Binding DisplayScore}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                            
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        
                        </DataGrid.Columns>
                    </DataGrid>

                    <Button Grid.Row="5" Content="Export to Excel" Command="{Binding ExportToExcelCommand}" 
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" 
                            Background="White" BorderBrush="Black" BorderThickness="2" 
                            FontSize="18" FontWeight="Bold" Padding="0,15" Margin="0,15,0,0"/>

                </Grid>
            </Border>

            <Border Grid.Column="1" BorderBrush="Black" BorderThickness="0,0,4,0" Padding="30" Background="#FAFAFA">
                <Panel>
                    <TextBlock Text="Select a student from the list to review their answers." 
                               IsVisible="{Binding CurrentVisibleQuestion, Converter={x:Static ObjectConverters.IsNull}}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20" Foreground="Gray"/>

                    <Grid RowDefinitions="*, Auto" IsVisible="{Binding CurrentVisibleQuestion, Converter={x:Static ObjectConverters.IsNotNull}}">
                        
                        <ScrollViewer Grid.Row="0">
                            <StackPanel Spacing="20">
                                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Top">
                                    <TextBlock Text="{Binding CurrentVisibleQuestion.QuestionNumber, StringFormat='{}{0})'}" FontSize="20" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding CurrentVisibleQuestion.Prompt}" FontSize="20" TextWrapping="Wrap" MaxWidth="500"/>
                                </StackPanel>
                                <Image Source="{Binding CurrentVisibleQuestion.ImageBitmap}" IsVisible="{Binding CurrentVisibleQuestion.ImageBitmap, Converter={x:Static ObjectConverters.IsNotNull}}" MaxHeight="300" HorizontalAlignment="Left" Margin="30,0,0,0"/>

                                <ItemsControl ItemsSource="{Binding CurrentVisibleQuestion.Choices}" IsVisible="{Binding CurrentVisibleQuestion.IsObjective}" Margin="30,20,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="models:ReviewChoice">
                                            <StackPanel Orientation="Vertical" Spacing="5" Margin="0,5">

                                                <StackPanel Orientation="Horizontal" Spacing="15">
                                                
                                                    <Border Width="30" Height="30" CornerRadius="{Binding BoxCornerRadius}" Background="{Binding BoxBackgroundColor}" BorderBrush="{Binding BoxBorderColor}" BorderThickness="2" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding InnerSymbol}" Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    
                                                    <TextBlock Text="{Binding Text}" FontSize="18" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                                </StackPanel>

                                                    <Image Source="{Binding ImageBitmap}" IsVisible="{Binding ImageBitmap, Converter={x:Static ObjectConverters.IsNotNull}}" MaxHeight="150" HorizontalAlignment="Left" Margin="70,0,0,0"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Border IsVisible="{Binding CurrentVisibleQuestion.IsEssay}" 
                                        Background="White" BorderBrush="LightGray" BorderThickness="1" Padding="15" Margin="30,20,0,0">
                                    <TextBlock Text="{Binding CurrentVisibleQuestion.EssayResponse}" TextWrapping="Wrap"/>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <Grid Grid.Row="1" ColumnDefinitions="Auto, *, Auto" Margin="0,20,0,0">
                            <Button Grid.Column="0" Content="&lt; Prev" Command="{Binding PrevQuestionCommand}" Background="Transparent" BorderBrush="Black" BorderThickness="2" FontSize="16" FontWeight="Bold" Padding="20,10"/>
                            
                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
                                <TextBox Text="{Binding CurrentVisibleQuestion.PointsInputText}" Width="60" FontSize="20" FontWeight="Bold" TextAlignment="Center" BorderBrush="Black" BorderThickness="1"/>
                                <TextBlock Text="{Binding CurrentVisibleQuestion.MaxPoints, StringFormat='{}/ {0} pts'}" FontSize="20" VerticalAlignment="Center"/>
                            </StackPanel>

                            <Button Grid.Column="2" Content="Next &gt;" Command="{Binding NextQuestionCommand}" Background="Transparent" BorderBrush="Black" BorderThickness="2" FontSize="16" FontWeight="Bold" Padding="20,10"/>
                        </Grid>

                    </Grid>
                </Panel>
            </Border>

            <Border Grid.Column="2" Padding="20" Background="White" BorderBrush="Black" BorderThickness="4,0,0,0">
                <Grid RowDefinitions="Auto, *, Auto" IsVisible="{Binding CurrentVisibleQuestion, Converter={x:Static ObjectConverters.IsNotNull}}">
                    
                    <Grid Grid.Row="0" ColumnDefinitions="*, Auto, *" Margin="0,0,0,20">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding CurrentTotalScore}" FontSize="24" FontWeight="Bold"/>
                            <TextBlock Text="{Binding CurrentMaxScore, StringFormat='{} / {0}'}" FontSize="24" Foreground="Gray"/>
                        </StackPanel>
                        
                        <Border Grid.Column="1" Width="3" Background="Black" Margin="10,0"/>
                        
                        <TextBlock Grid.Column="2" Text="{Binding CurrentTimeTakenDisplay}" FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Grid>

                    <ScrollViewer Grid.Row="1" Margin="0,10">
                        
                        <ItemsControl ItemsSource="{Binding CurrentReviewSections}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:ReviewSection">
                                    
                                    <StackPanel Margin="0,0,0,20">
                                        
                                        <ItemsControl ItemsSource="{Binding Questions}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>

                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="models:ReviewQuestion">
                                                    <Button Command="{Binding #RootView.DataContext.JumpToQuestionCommand}" 
                                                            CommandParameter="{Binding}"
                                                            Background="White" BorderBrush="Black" BorderThickness="1" 
                                                            Width="75" Height="50" Margin="5" Padding="5">
                                                        <Grid ColumnDefinitions="Auto, *">
                                                            <TextBlock Grid.Column="0" Text="{Binding GridIcon}" Foreground="{Binding GridIconColor}" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding QuestionNumber}" FontSize="16" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Button Grid.Row="2" Content="Finish Checking" Command="{Binding FinishCheckingCommand}" 
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" 
                            Background="White" BorderBrush="Black" BorderThickness="2" 
                            FontSize="18" FontWeight="Bold" Padding="0,15" Margin="0,20,0,0"/>

                </Grid>
            </Border>

        </Grid>
    </Grid>
</UserControl>