<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ScriviTest.ViewModels.Examinee"
             xmlns:dto="using:ScriviTest.DTOs"
             x:Class="ScriviTest.Views.Examinee.ExamineeTestView"
             x:DataType="vm:ExamineeTestViewModel"
             x:Name="RootView"
             Background="{DynamicResource AppBackground}">

    <Grid>
        <Border ZIndex="100" Background="#DD000000" IsVisible="{Binding IsLightboxOpen}">
            <Grid>
                <Image Source="{Binding LightboxImage}" Margin="50" Stretch="Uniform"/>
                <Button Content="✕ Close Image" Command="{Binding CloseLightboxCommand}" 
                        HorizontalAlignment="Right" VerticalAlignment="Top" Margin="20"
                        Background="#F44336" Foreground="White" FontSize="18" FontWeight="Bold" Padding="15,10"/>
            </Grid>
        </Border>

        <Grid RowDefinitions="Auto, *">
            
            <Border Grid.Row="0" Background="{DynamicResource PrimaryActionBrush}" Padding="20" BoxShadow="0 2 10 0 Gray">
                <StackPanel>
                    <TextBlock Text="{Binding ExamData.Title}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource ActionTextBrush}"/>
                    <TextBlock Text="{Binding ExamData.Teacher, StringFormat='Instructor: {0}'}" FontSize="14" Foreground="{DynamicResource ActionTextBrush}" Opacity="0.8"/>
                </StackPanel>
            </Border>

            <Grid Grid.Row="1" ColumnDefinitions="3*, 1*">
                
                <Border Grid.Column="0" Background="White" Padding="40" Margin="20" CornerRadius="10" BoxShadow="0 4 15 0 LightGray">
                    <Grid RowDefinitions="*, Auto">
                        
                        <ScrollViewer Grid.Row="0">
                            <StackPanel Spacing="20" DataContext="{Binding CurrentQuestion}">
                                
                                <Grid ColumnDefinitions="Auto, *">
                                    <TextBlock Grid.Column="0" Text="{Binding DisplayNumber, StringFormat='{}{0}. '}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource PrimaryActionBrush}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Question.Prompt}" FontSize="22" FontWeight="SemiBold" TextWrapping="Wrap" Foreground="{DynamicResource AppForeground}"/>
                                </Grid>

                                <TextBlock Text="{Binding Question.Points, StringFormat='[{0} pts]'}" FontWeight="Bold" Foreground="Gray" Margin="0,-10,0,10"/>

                                <Button Command="{Binding #RootView.DataContext.OpenLightboxCommand}" CommandParameter="{Binding Question.ImageBitmap}"
                                        IsVisible="{Binding Question.ImageBitmap, Converter={x:Static ObjectConverters.IsNotNull}}"
                                        Background="Transparent" HorizontalAlignment="Left" Padding="0" Cursor="Hand" ToolTip.Tip="Click to enlarge image">
                                    <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="4" Padding="5">
                                        <Image Source="{Binding Question.ImageBitmap}" MaxHeight="300"/>
                                    </Border>
                                </Button>

                                <TextBox IsVisible="{Binding Question.IsEssay}" 
                                         Text="{Binding Question.StudentEssayResponse}" 
                                         AcceptsReturn="True" TextWrapping="Wrap" MinHeight="250" FontSize="18"
                                         Watermark="Type your essay response here..."/>
                                
                                <ItemsControl ItemsSource="{Binding Question.Choices}" IsVisible="{Binding Question.IsObjective}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="dto:StudentChoiceDto">
                                            <Border Background="#FAFAFA" CornerRadius="8" Padding="15" Margin="0,5" BorderBrush="#EEEEEE" BorderThickness="1">
                                                <Grid ColumnDefinitions="Auto, *">
                                                    
                                                    <RadioButton Grid.Column="0" IsVisible="{Binding $parent[ItemsControl].((vm:ExamineeQuestionWrapper)DataContext).Question.IsSingleSelection}" 
                                                                 IsChecked="{Binding IsSelected}" 
                                                                 GroupName="{Binding $parent[ItemsControl].((vm:ExamineeQuestionWrapper)DataContext).Question.GroupId}" 
                                                                 Margin="0,0,15,0" VerticalAlignment="Center"/>

                                                    <CheckBox Grid.Column="0" IsVisible="{Binding $parent[ItemsControl].((vm:ExamineeQuestionWrapper)DataContext).Question.IsMultipleSelection}" 
                                                              IsChecked="{Binding IsSelected}" 
                                                              Margin="0,0,15,0" VerticalAlignment="Center"/>
                                                    
                                                    <StackPanel Grid.Column="1" Spacing="10">
                                                        <TextBlock Text="{Binding Text}" TextWrapping="Wrap" FontSize="18" VerticalAlignment="Center" Foreground="{DynamicResource AppForeground}"/>
                                                        
                                                        <Button Command="{Binding #RootView.DataContext.OpenLightboxCommand}" CommandParameter="{Binding ImageBitmap}"
                                                                IsVisible="{Binding ImageBitmap, Converter={x:Static ObjectConverters.IsNotNull}}"
                                                                Background="Transparent" HorizontalAlignment="Left" Padding="0" Cursor="Hand" ToolTip.Tip="Click to enlarge image">
                                                            <Image Source="{Binding ImageBitmap}" MaxHeight="150"/>
                                                        </Button>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>

                        <Border Grid.Row="1" Margin="0,20,0,0" Padding="0,20,0,0" BorderThickness="0,2,0,0" BorderBrush="LightGray">
                            <Grid ColumnDefinitions="Auto, *, Auto">
                                <Button Grid.Column="0" Content="← Previous" Command="{Binding PrevQuestionCommand}" FontSize="18" Padding="20,10" Background="Transparent" BorderBrush="Gray" BorderThickness="1"/>
                                
                                <Button Grid.Column="1" Content="⚑ Flag for Review" Command="{Binding ToggleFlagCommand}" HorizontalAlignment="Center" FontSize="16" Padding="20,10" Background="Transparent" Foreground="#F57F17" BorderBrush="#F57F17" BorderThickness="1"/>
                                
                                <Button Grid.Column="2" Content="Next →" Command="{Binding NextQuestionCommand}" FontSize="18" FontWeight="Bold" Padding="30,10" Background="{DynamicResource PrimaryActionBrush}" Foreground="White"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Background="#FAFAFA" BorderBrush="LightGray" BorderThickness="2,0,0,0" Padding="20">
                    <Grid RowDefinitions="Auto, *, Auto">
                        
                        <Border Grid.Row="0" Background="#333333" CornerRadius="8" Padding="15" Margin="0,0,0,20" HorizontalAlignment="Stretch">
                            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="⏱️" FontSize="24" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding TimeRemainingDisplay}" FontSize="28" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <ScrollViewer Grid.Row="1" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="Question Navigation" FontWeight="Bold" FontSize="18" Margin="0,0,0,15" Foreground="Gray"/>
                                
                                <ItemsControl ItemsSource="{Binding AllQuestions}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>

                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ExamineeQuestionWrapper">
                                            <Button Command="{Binding #RootView.DataContext.JumpToQuestionCommand}" 
                                                    CommandParameter="{Binding}"
                                                    Background="{Binding GridBackgroundColor}" 
                                                    BorderBrush="Black" 
                                                    BorderThickness="{Binding GridBorderThickness}" 
                                                    Width="60" Height="50" Margin="5" Padding="5">
                                                <Grid ColumnDefinitions="Auto, *">
                                                    <TextBlock Grid.Column="0" Text="{Binding GridIcon}" Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding DisplayNumber}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>

                        <Button Grid.Row="2" Content="SUBMIT EXAM" Command="{Binding SubmitExamCommand}" 
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" 
                                Background="#4CAF50" Foreground="White" 
                                Padding="0,20" FontSize="20" FontWeight="Bold"/>

                    </Grid>
                </Border>

            </Grid>
        </Grid>
    </Grid>
</UserControl>