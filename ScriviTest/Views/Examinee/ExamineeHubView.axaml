<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ScriviTest.ViewModels.Examinee"
             xmlns:models="using:ScriviTest.Models" 
             x:Class="ScriviTest.Views.Examinee.ExamineeHubView"
             x:DataType="vm:ExamineeHubViewModel"
             Background="{DynamicResource AppBackground}">

    <Grid RowDefinitions="Auto, *">
        
        <Border Grid.Row="0" Background="White" Padding="15" BoxShadow="0 2 5 0 LightGray">
            <Button Content="← Cancel &amp; Return" Command="{Binding GoBackCommand}" Background="Transparent" Foreground="{DynamicResource AppForeground}"/>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="40" BoxShadow="0 8 20 0 LightGray" 
                HorizontalAlignment="Center" VerticalAlignment="Center" Width="500">
            
            <StackPanel Spacing="25">
                <TextBlock Text="Examinee Portal" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{DynamicResource PrimaryActionBrush}"/>
                <TextBlock Text="Please load your examination file and enter the whiteboard key provided by your instructor." 
                           TextWrapping="Wrap" TextAlignment="Center" Foreground="{DynamicResource AppForeground}" Opacity="0.7"/>

                <Separator Background="LightGray" Margin="0,10"/>

                <StackPanel Spacing="10">
                    <TextBlock Text="1. Load Examination File (.xamn)" FontWeight="SemiBold" Foreground="{DynamicResource AppForeground}"/>
                    <Grid ColumnDefinitions="*, Auto">
                        <Border Grid.Column="0" Background="#F5F5F5" BorderBrush="LightGray" BorderThickness="1" CornerRadius="4" Padding="10">
                            <TextBlock Text="{Binding SelectedFileName}" VerticalAlignment="Center" Foreground="{DynamicResource AppForeground}"/>
                        </Border>
                        <Button Grid.Column="1" Content="Browse..." Command="{Binding BrowseForExamCommand}" 
                                Background="{DynamicResource StandardButtonBrush}" Foreground="{DynamicResource AppForeground}" Padding="15,10"/>
                    </Grid>
                </StackPanel>

                <StackPanel Spacing="10">
                    <TextBlock Text="2. Examination Key" FontWeight="SemiBold" Foreground="{DynamicResource AppForeground}"/>
                    <TextBox Text="{Binding WhiteboardKey}" MaxLength="6" FontSize="24" FontWeight="Bold" HorizontalContentAlignment="Center" 
                             Watermark="XXXXXX" BorderThickness="1" BorderBrush="LightGray" Foreground="{DynamicResource AppForeground}"/>
                </StackPanel>

                <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" FontWeight="SemiBold" HorizontalAlignment="Center" 
                           IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                <Button Content="UNLOCK &amp; START EXAM" Command="{Binding StartExamCommand}" 
                        Background="{DynamicResource PrimaryActionBrush}" Foreground="{DynamicResource ActionTextBrush}" 
                        FontSize="18" FontWeight="Bold" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="0,15" Margin="0,10,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>