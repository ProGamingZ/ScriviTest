<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ScriviTest.ViewModels.Examinee"
             xmlns:models="using:ScriviTest.Models" 
             x:Class="ScriviTest.Views.Examinee.ExamineeHubView"
             x:DataType="vm:ExamineeHubViewModel"
             Background="{DynamicResource AppBackground}">

    <Grid RowDefinitions="Auto, *">
        
        <Border Grid.Row="0" Background="White" Padding="15" BoxShadow="0 2 5 0 LightGray">
            <Button Content="← Cancel &amp; Return" Command="{Binding GoBackCommand}" Background="Transparent" Foreground="{DynamicResource AppForeground}"/>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="40" BoxShadow="0 8 20 0 LightGray" 
                HorizontalAlignment="Center" VerticalAlignment="Center" Width="600">
            
            <StackPanel Spacing="25">
                <TextBlock Text="Examinee Portal" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{DynamicResource PrimaryActionBrush}"/>
                <TextBlock Text="Please enter your details and load your examination file." 
                           TextWrapping="Wrap" TextAlignment="Center" Foreground="{DynamicResource AppForeground}" Opacity="0.7"/>

                <Separator Background="LightGray" Margin="0,5"/>

                <TextBlock Text="Student Information" FontWeight="Bold" Foreground="{DynamicResource PrimaryActionBrush}"/>
                
                <Grid RowDefinitions="Auto, Auto, Auto" ColumnDefinitions="*, *" Margin="0,0,0,10">
                    
                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,10">
                        <TextBlock Text="First Name *" FontSize="12" Foreground="Gray" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding FirstName}" Watermark="First Name"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="10,0,0,10">
                        <TextBlock Text="Middle Name" FontSize="12" Foreground="Gray" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding MiddleName}" Watermark="Middle Name"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,10">
                        <TextBlock Text="Last Name *" FontSize="12" Foreground="Gray" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding LastName}" Watermark="Last Name"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="10,0,0,10">
                        <TextBlock Text="Suffix (e.g., Jr.)" FontSize="12" Foreground="Gray" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding Suffix}" Watermark="Suffix"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,10">
                        <TextBlock Text="Student ID *" FontSize="12" Foreground="Gray" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding StudentID}" Watermark="Student Identification Number"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Examination Details" FontWeight="Bold" Foreground="{DynamicResource PrimaryActionBrush}"/>

                <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="*, Auto">
                        <TextBox Grid.Column="0" Text="{Binding SelectedFileName}" IsReadOnly="True" Watermark="Load Examination File (.xamn)"/>
                        <Button Grid.Column="1" Content="Browse..." Command="{Binding BrowseForExamCommand}" Margin="10,0,0,0"/>
                    </Grid>

                    <TextBox Text="{Binding WhiteboardKey}" MaxLength="6" FontSize="18" FontWeight="Bold" HorizontalContentAlignment="Center" 
                             Watermark="6-Character Decryption Key" BorderThickness="1" Foreground="{DynamicResource AppForeground}"/>
                </StackPanel>

                <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" FontWeight="SemiBold" HorizontalAlignment="Center" 
                           IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                <Button Content="UNLOCK &amp; START EXAM" Command="{Binding StartExamCommand}" 
                        Background="{DynamicResource PrimaryActionBrush}" Foreground="{DynamicResource ActionTextBrush}" 
                        FontSize="18" FontWeight="Bold" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="0,15" Margin="0,10,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>