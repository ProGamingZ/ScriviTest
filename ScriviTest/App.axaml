<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:ScriviTest"
             x:Class="ScriviTest.App"
             RequestedThemeVariant="Dark">
             <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml"/>
    </Application.Styles>

    <Application.Resources>

        <ResourceDictionary>
        <ResourceDictionary.ThemeDictionaries>
            
            <!-- ====== LIGHT MODE BRUSHES ====== -->
            <ResourceDictionary x:Key="Light">
                <SolidColorBrush x:Key="AppBackground">#F5F5F5</SolidColorBrush>
                <SolidColorBrush x:Key="AppForeground">#1A1A1A</SolidColorBrush>
                <SolidColorBrush x:Key="SurfaceBrush">#FFFFFF</SolidColorBrush>
                <SolidColorBrush x:Key="SurfaceAltBrush">#FAFAFA</SolidColorBrush>
                
                <SolidColorBrush x:Key="PrimaryActionBrush">#1e88e5</SolidColorBrush>   
                <SolidColorBrush x:Key="SecondaryActionBrush">#43a047</SolidColorBrush> 
                <SolidColorBrush x:Key="DangerActionBrush">#D32F2F</SolidColorBrush>
                <SolidColorBrush x:Key="ActionTextBrush">#FFFFFF</SolidColorBrush>      
                <SolidColorBrush x:Key="StandardButtonBrush">#E0E0E0</SolidColorBrush>
                <SolidColorBrush x:Key="ActivateButtonBrush">#2b2b2b</SolidColorBrush>

                <SolidColorBrush x:Key="BorderLightBrush">LightGray</SolidColorBrush>
                <SolidColorBrush x:Key="BorderDarkBrush">Gray</SolidColorBrush>
                <SolidColorBrush x:Key="ErrorTextBrush">Red</SolidColorBrush>
                <SolidColorBrush x:Key="ErrorBackgroundBrush">#FFEBEE</SolidColorBrush>
                <SolidColorBrush x:Key="WarningTextBrush">#F57F17</SolidColorBrush>
                <SolidColorBrush x:Key="HighlightBackgroundBrush">#FFF9C4</SolidColorBrush>
                <SolidColorBrush x:Key="InfoBackgroundBrush">#E3F2FD</SolidColorBrush>

                <SolidColorBrush x:Key="OverlayBackgroundBrush">#AA000000</SolidColorBrush>
                <SolidColorBrush x:Key="OverlayDarkBackgroundBrush">#DD000000</SolidColorBrush>
                <SolidColorBrush x:Key="DangerOverlayBrush">#DDFF0000</SolidColorBrush>

                <BoxShadows x:Key="HeaderShadow">0 2 10 0 Gray</BoxShadows>
                <BoxShadows x:Key="CardShadow">0 4 15 0 LightGray</BoxShadows>
                <BoxShadows x:Key="DialogShadow">0 10 30 0 Black</BoxShadows>
                <BoxShadows x:Key="TopBarShadow">0 2 5 0 LightGray</BoxShadows>
                <BoxShadows x:Key="BottomBarShadow">0 -2 5 0 LightGray</BoxShadows>
                <BoxShadows x:Key="PortalShadow">0 8 20 0 LightGray</BoxShadows>
                <BoxShadows x:Key="ToastShadow">0 4 15 0 #40000000</BoxShadows>   

                <SolidColorBrush x:Key="nth-child">#F0F0F0</SolidColorBrush>
                <SolidColorBrush x:Key="pointerover">#e8e8e8</SolidColorBrush>
                <SolidColorBrush x:Key="selected:pointerover">#dddddd</SolidColorBrush> 
            </ResourceDictionary>

            <!-- ====== DARK MODE BRUSHES ====== -->
            <ResourceDictionary x:Key="Dark">
                <SolidColorBrush x:Key="AppBackground">#121212</SolidColorBrush>
                <SolidColorBrush x:Key="AppForeground">#E0E0E0</SolidColorBrush>
                <SolidColorBrush x:Key="SurfaceBrush">#1E1E1E</SolidColorBrush>
                <SolidColorBrush x:Key="SurfaceAltBrush">#252525</SolidColorBrush>

                <!-- Action colors are slightly lighter/desaturated for better readability on dark backgrounds -->
                <SolidColorBrush x:Key="PrimaryActionBrush">#64B5F6</SolidColorBrush>   
                <SolidColorBrush x:Key="SecondaryActionBrush">#81C784</SolidColorBrush> 
                <SolidColorBrush x:Key="DangerActionBrush">#E57373</SolidColorBrush>
                <!-- Dark text provides the best contrast against the lighter action brushes above -->
                <SolidColorBrush x:Key="ActionTextBrush">#121212</SolidColorBrush>      
                <SolidColorBrush x:Key="StandardButtonBrush">#333333</SolidColorBrush>
                <SolidColorBrush x:Key="ActivateButtonBrush">#E0E0E0</SolidColorBrush>

                <SolidColorBrush x:Key="BorderLightBrush">#424242</SolidColorBrush>
                <SolidColorBrush x:Key="BorderDarkBrush">#616161</SolidColorBrush>
                <SolidColorBrush x:Key="ErrorTextBrush">#EF5350</SolidColorBrush>
                <!-- Info/Warning/Error backgrounds shifted to dark, tinted grays to prevent blinding contrast -->
                <SolidColorBrush x:Key="ErrorBackgroundBrush">#3B1D1D</SolidColorBrush>
                <SolidColorBrush x:Key="WarningTextBrush">#FFB300</SolidColorBrush>
                <SolidColorBrush x:Key="HighlightBackgroundBrush">#332B00</SolidColorBrush>
                <SolidColorBrush x:Key="InfoBackgroundBrush">#0D2233</SolidColorBrush>

                <SolidColorBrush x:Key="OverlayBackgroundBrush">#AA000000</SolidColorBrush>
                <SolidColorBrush x:Key="OverlayDarkBackgroundBrush">#E6000000</SolidColorBrush>
                <!-- Danger overlay opacity reduced slightly so it isn't too jarring -->
                <SolidColorBrush x:Key="DangerOverlayBrush">#66FF0000</SolidColorBrush>

                <!-- Shadows must be black or near-black in dark mode, otherwise they look like outer glows -->
                <BoxShadows x:Key="HeaderShadow">0 2 10 0 #000000</BoxShadows>
                <BoxShadows x:Key="CardShadow">0 4 15 0 #000000</BoxShadows>
                <BoxShadows x:Key="DialogShadow">0 10 30 0 #000000</BoxShadows>
                <BoxShadows x:Key="TopBarShadow">0 2 5 0 #000000</BoxShadows>
                <BoxShadows x:Key="BottomBarShadow">0 -2 5 0 #000000</BoxShadows>
                <BoxShadows x:Key="PortalShadow">0 8 20 0 #000000</BoxShadows>
                <BoxShadows x:Key="ToastShadow">0 4 15 0 #80000000</BoxShadows>   

                <!-- Subtle hover and list states building up from the SurfaceBrush (#1E1E1E) -->
                <SolidColorBrush x:Key="nth-child">#222222</SolidColorBrush>
                <SolidColorBrush x:Key="pointerover">#2A2A2A</SolidColorBrush>
                <SolidColorBrush x:Key="selected:pointerover">#333333</SolidColorBrush>   
            </ResourceDictionary> 
            
            
        </ResourceDictionary.ThemeDictionaries>   

        <!-- CENTRALIZED ICONS (Strings) -->
        <x:String x:Key="IconBack">←</x:String>
        <x:String x:Key="IconNext">→</x:String>
        <x:String x:Key="IconClose">✕</x:String>
        <x:String x:Key="IconWarning">⚠️</x:String>
        <x:String x:Key="IconDelete">🗑️</x:String>
        <x:String x:Key="IconSettings">⚙️</x:String>
        <x:String x:Key="IconImage">🖼️</x:String>
        <x:String x:Key="IconTimer">⏱️</x:String>
        <x:String x:Key="IconImport">📥</x:String>
        <x:String x:Key="IconSave">💾</x:String>
        <x:String x:Key="IconFlag">⚑</x:String>
        <x:String x:Key="IconDoc">📄</x:String>
        <x:String x:Key="IconKey">🔑</x:String>

        
        </ResourceDictionary>
    </Application.Resources>
</Application>