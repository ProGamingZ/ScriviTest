<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:ScriviTest"
             x:Class="ScriviTest.App"
             RequestedThemeVariant="Light">
             <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>

    <Application.Resources>
        <SolidColorBrush x:Key="AppBackground">#F5F5F5</SolidColorBrush>
        <SolidColorBrush x:Key="AppForeground">#1A1A1A</SolidColorBrush>

        <SolidColorBrush x:Key="PrimaryActionBrush">#1e88e5</SolidColorBrush>   <SolidColorBrush x:Key="SecondaryActionBrush">#43a047</SolidColorBrush> <SolidColorBrush x:Key="ActionTextBrush">#FFFFFF</SolidColorBrush>      <SolidColorBrush x:Key="StandardButtonBrush">#E0E0E0</SolidColorBrush>
        <SolidColorBrush x:Key="ActivateButtonBrush">#2b2b2b</SolidColorBrush>
    </Application.Resources>

</Application>